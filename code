const fs = require("fs");

var TAB = " ";
var LE = "\n";
var header = "#%RAML 1.0 DataType" + LE;

var keysOptional = false;
var keysCamelCased = false;

function convert(jsonInput) {

let opString = "";

if (jsonInput == '' || jsonInput == null) {
return "Input is Empty";
}

if (!isValidJSONString(jsonInput)) {
return "Invalid JSON";
}

opString = header + buildRoot(jsonInput);

return opString.replace("\n\n", "\n");
}

function isValidJSONString(str) {
try {
JSON.parse(str);
} catch (e) {
return false;
}
return true;
}

function buildRoot(str) {

let type = "";
let inpJson = JSON.parse(str);

if (Array.isArray(inpJson)) {

type = "type: array" + LE + "items :" + LE;
type += buildArray(true, inpJson, 1);

} else if (typeof inpJson === "object") {

type = "type: object" + LE + "properties:" + LE;
type += buildObject(true, inpJson, 1);

}

return type;
}

function buildObject(isRootObj, str, level) {

let obj = "";

if (!isRootObj) {

level++;
obj = getTabs(level) + "properties:";

}

level++;

for (let key in str) {

obj += LE + getTabs(level) + getElementType(key, str[key], level);

}

return obj;
}

function buildArray(isRootObj, array, level) {

let obj = "";

if (array.length > 0) {

if (!isRootObj) {

level++;
obj = getTabs(level) + "items:";

}

level++;
obj += LE + getTabs(level) + getElementType(null, array[0], level);

}

return obj;
}

function getElementType(key, str, level) {

let type = "";

if (keysOptional) {
key = (key === null) ? null : key + "?";
}

key = (key === null) ? "type" : key;

if (Array.isArray(str)) {

type = key + ": " + LE + buildArray(false, str, level);

}

else if (str === null) {

type = key + ": nil";

}

else if (typeof str === "object") {

type = key + ":" + LE + buildObject(false, str, level);

}

else if (typeof str === "string") {

type = key + ": string";

}

else if (typeof str === "number") {

type = key + ": number";

}

else if (typeof str === "boolean") {

type = key + ": boolean";

}

return type;
}

function getTabs(level) {

let tabs = "";

for (let i = 0; i < level; i++) {
tabs += TAB;
}

return tabs;
}

//// MAIN EXECUTION

const inputFile = "input.json";
const outputFile = "output.raml";

const jsonInput = fs.readFileSync(inputFile, "utf8");

const raml = convert(jsonInput);

fs.writeFileSync(outputFile, raml);

console.log("✅ RAML generated successfully -> output.raml");
